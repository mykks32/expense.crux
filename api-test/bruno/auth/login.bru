meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "srikri5462ydv@gmail.com",
    "password": "Password@123"
  }
}

script:post-response {
  if (res.body?.data?.accessToken) {
    bru.setEnvVar("accessToken", res.body.data.accessToken);
    bru.setEnvVar("refreshToken", res.body.data.refreshToken);
  }
}

docs {
  ## Login
  
  `POST /auth/login` — authenticates by email/password and issues a fresh token pair. Public (no auth).
  
  ### Body
  | Field | Type | Required |
  |---|---|---|
  | `email` | string | yes |
  | `password` | string | yes |
  
  ### Response
  `200 OK` — `data`: `{ accessToken, refreshToken, user: { id, email, name? } }`.
  
  ### Errors
  `invalidCredentials` on a bad email/password.
}

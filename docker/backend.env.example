# Host is "mongo" — the service name docker-compose.yml registers on the
# shared network. If you're instead running standalone (see README's
# "No external Mongo? Run one alongside it" section), use that container's
# name instead (e.g. expense-crux-mongo).
MONGO_URI=mongodb://mongo:mongo@mongo:27017/expense_crux?authSource=admin
JWT_ACCESS_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
JWT_REFRESH_SECRET=change-me-too-in-production
REFRESH_TOKEN_TTL=7d

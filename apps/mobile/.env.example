# Copy to .env and fill in your backend's reachable address.
#
# - iOS Simulator / Android Emulator: http://localhost:3000 works.
# - Expo Go on a physical device: the phone can't reach "localhost" (that's
#   the phone itself) — use your machine's LAN IP instead, e.g.
#   http://192.168.1.77:3000. Find it with `ipconfig getifaddr en0` (macOS Wi-Fi).
# - Must be prefixed EXPO_PUBLIC_ to be readable from app code (Expo inlines
#   only EXPO_PUBLIC_* vars into the client bundle).
EXPO_PUBLIC_API_URL=http://localhost:3000

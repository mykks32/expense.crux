# Copy to env/server.env and fill in real secrets. Used for local dev and
# docker compose alike (docker/docker-compose.yml — same file whether its
# server service builds from the local Dockerfile or uses the published
# GHCR image; see the comment there to switch between the two).
#
# MONGO_URI's host depends on how you're running the server — only one of the
# two lines below should be uncommented at a time:
PORT=3000

# Local (non-Docker) dev — mongo reached via the host-mapped port:
MONGO_URI=mongodb://mongo:mongo@localhost:27017/expense_crux?authSource=admin
# Docker compose — mongo reached via the compose service name instead:
# MONGO_URI=mongodb://mongo:mongo@mongo:27017/expense_crux?authSource=admin

JWT_ACCESS_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
JWT_REFRESH_SECRET=change-me-too-in-production
REFRESH_TOKEN_TTL=7d

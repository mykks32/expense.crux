# Copy to env/backend.env and fill in real secrets. Used for local dev,
# docker compose, and scripts/run-standalone.sh alike.
#
# MONGO_URI's host depends on how you're running the backend — edit it
# to match before switching between modes:
#   local (non-Docker) dev  -> localhost
#   docker compose          -> mongo            (the compose service name)
#   scripts/run-standalone.sh -> expense-crux-mongo (the container name it creates)
PORT=3000
MONGO_URI=mongodb://mongo:mongo@localhost:27017/expense_crux?authSource=admin
JWT_ACCESS_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
JWT_REFRESH_SECRET=change-me-too-in-production
REFRESH_TOKEN_TTL=7d

# Copy to env/web.env and point at your backend's reachable address.
# Read at build time (Vite's import.meta.env), not container runtime, so it
# must be a URL the browser can reach — never a Docker Compose service name.
VITE_API_URL=http://localhost:3000

# Bundles + shows the TanStack Query/Router devtools panels, independent of
# `vite dev` vs `vite build` — set to false before a real production deploy.
VITE_ENABLE_DEVTOOLS=true
